# Not published in this repository:
#   paper/       manuscript, supplement, reviews (kept out of the code release)
#   checkpoints/ trained policies, ~1-6 GB each; regenerate via stage 1 (README)
#   scratch/     throwaway working files and pipeline logs
paper/
checkpoints/
scratch/

# Large regenerable data: raw rollout logs (rich_logs.pkl) come from stage 2
# of the README pipeline; figures are regenerated by the analysis scripts.
*.pkl
*.npz
results/**/videos/
results/**/*.mp4
results/**/*.png
results/**/*.pdf

# Junk
__pycache__/
*.pyc
*.log
*.bak*
nohup.out
wandb/
.DS_Store
